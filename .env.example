# ============================================================
# 文心健康管家 Demo - 环境变量模板
# ------------------------------------------------------------
# 用法：
#   1. 复制本文件为 .env：    cp .env.example .env
#   2. 编辑 .env，把下面的占位符替换为真实值
#   3. 启动：                 ./run.sh
# 注意：.env 文件已在 .gitignore 中，不会被提交到 GitHub
# ============================================================

# ---------- 模型 API（必填） ----------
# OneAPI / OpenAI 兼容网关地址
OPENAI_BASE_URL=https://your-oneapi-host/v1

# 你的 API Key（从 OneAPI 后台或服务方拿）
OPENAI_API_KEY=sk-your-api-key-here

# 模型名（如 DeepSeek-V4-Flash、gpt-4o、ernie-4.5-turbo-128k 等）
OPENAI_MODEL=DeepSeek-V4-Flash

# 模型接口模式：默认走 OpenAI chat/completions；DeepSeek V4 Flash 建议使用 messages
# MODEL_TYPE=messages

# ---------- 运行模式（必填） ----------
# 消息类型：agentic（推荐）或 standard
MESSAGE_KIND=agentic

# ---------- 可选 ----------
# 服务端口，默认 8080
# PORT=8080

# Skill 目录；默认由 run.sh 指向项目内置健康管家 skills
# EINO_EXT_SKILLS_DIR=/absolute/path/to/eino_pm/eino-examples/quickstart/chatwitheino/skills/health

# CozeLoop 链路追踪（不填则关闭）
# COZELOOP_API_TOKEN=
# COZELOOP_WORKSPACE_ID=
